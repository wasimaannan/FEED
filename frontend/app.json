{
  "expo": {
    "name": "FEED Entry System",
    "slug": "feed-entry-system",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/feed logo akij.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/feed logo akij.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "android": {
      "icon": "./assets/feed logo akij.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/feed logo akij.png",
        "backgroundColor": "#1A3A6B"
      },
      "package": "com.feedentry.app",
      "permissions": ["INTERNET"],
      "newArchEnabled": false
    },
    "ios": {
      "supportsTablet": false,
      "newArchEnabled": false
    }
  }
}